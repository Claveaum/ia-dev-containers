{
  // ⚠️ FICHIER GÉNÉRÉ — ne pas éditer directement, éditer
  // devcontainer.json.template puis relancer `./scripts/run.sh up`
  // (qui régénère ce fichier via render_devcontainer() dans run.sh).
  //
  // ⚠️ PRÉREQUIS OBLIGATOIRE : ce devcontainer ne construit/lance que le
  // conteneur "workspace". Le conteneur "gateway" (proxy Squid, filtrage
  // réseau) et le réseau interne dédié à ce projet doivent déjà exister
  // AVANT d'ouvrir ce dossier dans VS Code :
  //
  //   cd clients/copilot && ./scripts/run.sh up
  //
  // Si le réseau __NETWORK_NAME__ n'existe pas encore, la création
  // du conteneur échouera (runArgs y fait référence ci-dessous).
  "name": "GitHub Copilot CLI - Workspace (sandbox à deux conteneurs)",
  "containerUser": "devuser",
  "remoteUser": "devuser",

  "build": {
    "dockerfile": "../workspace/Dockerfile",
    "context": ".."
  },

  // /workspace est un bind-mount de la racine du projet (le dossier parent
  // de cette copie de ia-dev-containers), pas un volume Podman : le CLI IA
  // travaille sur les vrais fichiers du projet. Voir le README (section
  // Sécurité) pour les implications (un fichier modifié par le CLI IA peut
  // ensuite s'exécuter côté hôte : hooks git, scripts de build...).
  "workspaceMount": "source=__PROJECT_ROOT__,target=/workspace,type=bind",
  "workspaceFolder": "/workspace",

  // Le premier élément de "mounts" ci-dessous remonte ia-dev-containers/ en
  // lecture seule sur lui-même quand cette copie est déposée à l'intérieur du
  // projet (voir README, section Architecture) — le CLI IA peut lire sa
  // propre config sandbox (git status normal) mais jamais l'écrire. Ligne
  // vide (donc pas de mount ajouté) si la copie a été relocalisée hors du
  // projet (IA_PROJECT_ROOT), si ia-dev-containers est lui-même le projet
  // sandboxé, ou si IA_SELF_MOUNT_RW=1. Calculée par render_devcontainer()
  // dans run.sh, placeholder substitué ci-dessous.
  "mounts": [
    __SELF_PROTECT_MOUNT__
    {
      "source": "__NPM_GLOBAL_VOLUME__",
      "target": "/home/devuser/.npm-global",
      "type": "volume"
    },
    // ~/.copilot (session, jeton d'auth après /login, logs) : sans ce
    // volume, ce chemin reste sous le filesystem racine en lecture seule et
    // le CLI plante en silence dès le premier lancement. Jeton déclaré par
    // ce client dans scripts/lib.sh (EXTRA_VOLUMES), résolu par
    // render_devcontainer() (scripts/orchestrator.sh) — même mécanisme que
    // le mount d'auto-protection tout en haut de ce tableau.
    __COPILOT_STATE_VOLUME__
    {
      "source": "__CACHE_VOLUME__",
      "target": "/home/devuser/.cache",
      "type": "volume"
    }
  ],

  "runArgs": [
    // Les flags suivants (userns, cap-drop, read-only, tmpfs, security-opt)
    // sont le contrat d'isolation du conteneur workspace — générés depuis
    // WORKSPACE_SECURITY_ARGS (scripts/common.sh) par render_devcontainer()
    // pour rester identiques aux flags que start_workspace() applique via
    // `podman run` (scripts/orchestrator.sh). Voir le commentaire sur
    // WORKSPACE_SECURITY_ARGS pour le détail de chaque flag (notamment
    // pourquoi `security-opt=label=disable` plutôt que `:Z` sur workspaceMount).
__WORKSPACE_SECURITY_ARGS__
    "--network=__NETWORK_NAME__",
    // L'URL du proxy ci-dessous est calculée par proxy_url() (scripts/
    // common.sh), même valeur que start_workspace() — respecte
    // GATEWAY_ADDR_MODE=static comme le chemin CLI, pas juste l'alias DNS
    // "gateway". Placeholder substitué par render_devcontainer().
    "-e=HTTP_PROXY=__PROXY_URL__",
    "-e=HTTPS_PROXY=__PROXY_URL__",
    "-e=IA_CLIENT=__CLIENT_NAME__"
  ],

  "postCreateCommand": "/security-tests.sh || echo '⚠️  Des tests ont échoué - vérifiez que ./scripts/run.sh up a bien été lancé AVANT d'\\''ouvrir ce dossier (le gateway doit déjà tourner).'",

  "postStartCommand": "echo '🎉 Conteneur workspace Copilot CLI prêt !' && echo '' && echo '   Proxy (via gateway) : http://gateway:3128' && echo '' && echo '   Pour installer le CLI :' && echo '   $ npm install -g @github/copilot' && echo '' && echo '   Seuls les remotes git en HTTPS fonctionnent (pas de SSH/port 22).'",

  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },

  "forwardPorts": [],
  "shutdownAction": "stop"
}
